noncomputable def gaussianProductMeasure (_œÉ : ‚Ñù) :
    @Measure (‚Ñï ‚Üí ‚Ñù) canonicalMeasurableSpace := by
  sorry

/-- Scaffold-level `IsFiniteMeasure` on the sorry'd product measure. The
canonical Gaussian product IS a probability measure (hence finite); the
